rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isEmployee(uid) {
      return isSignedIn()
        && request.auth.token.role == 'employee'
        && request.auth.uid == uid;
    }

    function isClient(uid) {
      return isSignedIn()
        && request.auth.token.role == 'client'
        && request.auth.uid == uid;
    }

    function isAnyEmployee() {
      return isSignedIn() && request.auth.token.role == 'employee';
    }

    function isAnyClient() {
      return isSignedIn() && request.auth.token.role == 'client';
    }

    // ─── employees/{uid} ─────────────────────────────────────────────────────
    match /employees/{uid} {
      allow read: if isEmployee(uid) || isAdmin();
      allow write: if isEmployee(uid) || isAdmin();
    }

    // ─── clients/{uid} ───────────────────────────────────────────────────────
    match /clients/{uid} {
      allow read: if isClient(uid) || isAdmin();
      allow write: if isClient(uid) || isAdmin();
    }

    // ─── admins/{uid} ────────────────────────────────────────────────────────
    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ─── attendance_logs/{logId} ─────────────────────────────────────────────
    match /attendance_logs/{logId} {
      // Employee can create their own; employee_uid must match auth uid
      allow create: if isAnyEmployee()
        && request.resource.data.employee_uid == request.auth.uid;
      // Employee can read their own logs
      allow read: if isAnyEmployee()
        && resource.data.employee_uid == request.auth.uid;
      // Admin can read all, write all
      allow read, write: if isAdmin();
    }

    // ─── leave_requests/{leaveId} ────────────────────────────────────────────
    match /leave_requests/{leaveId} {
      // Employee can create own
      allow create: if isAnyEmployee()
        && request.resource.data.employee_uid == request.auth.uid;
      // Employee can read own
      allow read: if isAnyEmployee()
        && resource.data.employee_uid == request.auth.uid;
      // Admin can read/write all
      allow read, write: if isAdmin();
    }

    // ─── payslips/{slipId} ───────────────────────────────────────────────────
    match /payslips/{slipId} {
      // Employee can read own
      allow read: if isAnyEmployee()
        && resource.data.employee_uid == request.auth.uid;
      // Admin can read/write all
      allow read, write: if isAdmin();
    }

    // ─── shifts/{shiftId} ────────────────────────────────────────────────────
    match /shifts/{shiftId} {
      // Employee can read own shifts
      allow read: if isAnyEmployee()
        && resource.data.employee_uid == request.auth.uid;
      // Admin can read/write all
      allow read, write: if isAdmin();
    }

    // ─── incidents/{incidentId} ──────────────────────────────────────────────
    match /incidents/{incidentId} {
      // Employee can create own
      allow create: if isAnyEmployee()
        && request.resource.data.employee_uid == request.auth.uid;
      // Employee can read own
      allow read: if isAnyEmployee()
        && resource.data.employee_uid == request.auth.uid;
      // Client can read incidents at their sites (client_uid set at incident creation)
      allow read: if isAnyClient()
        && resource.data.client_uid == request.auth.uid;
      // Admin can read all
      allow read: if isAdmin();
      // Admin can write all (update status, etc.)
      allow write: if isAdmin();
    }

    // ─── complaints/{complaintId} ────────────────────────────────────────────
    match /complaints/{complaintId} {
      // Client can create own
      allow create: if isAnyClient()
        && request.resource.data.client_uid == request.auth.uid;
      // Client can read own
      allow read: if isAnyClient()
        && resource.data.client_uid == request.auth.uid;
      // Admin can read/write all
      allow read, write: if isAdmin();
    }

    // ─── daily_reports/{reportId} ────────────────────────────────────────────
    match /daily_reports/{reportId} {
      // Client can read reports for their sites.
      // site_client_uid field on the report stores the owning client's uid.
      allow read: if isAnyClient()
        && resource.data.site_client_uid == request.auth.uid;
      // Admin can read/write all
      allow read, write: if isAdmin();
    }

    // ─── invoices/{invoiceId} ────────────────────────────────────────────────
    match /invoices/{invoiceId} {
      // Client can read own invoices
      allow read: if isAnyClient()
        && resource.data.client_uid == request.auth.uid;
      // Admin can read/write all
      allow read, write: if isAdmin();
    }

    // ─── sites/{siteId} ──────────────────────────────────────────────────────
    match /sites/{siteId} {
      // Any authenticated employee or client can read
      allow read: if isAnyEmployee() || isAnyClient() || isAdmin();
      // Only admin can write
      allow write: if isAdmin();
    }

    // ─── companies/{companyId} ───────────────────────────────────────────────
    match /companies/{companyId} {
      allow read, write: if isAdmin();
    }

    // ─── activity_log/{logId} ────────────────────────────────────────────────
    // Admin read only; writes happen server-side (Cloud Functions with admin SDK bypass rules)
    match /activity_log/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only server-side admin SDK writes
    }

    // ─── pending_registrations/{regId} ───────────────────────────────────────
    // Unauthenticated users can create (employee self-registration flow)
    match /pending_registrations/{regId} {
      allow create: if true; // Open for self-registration
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ─── guard_keycodes/{keycode} ─────────────────────────────────────────────
    // Keycodes are validated server-side only (Cloud Functions with admin SDK
    // bypass rules). Client SDK never reads or writes these directly.
    match /guard_keycodes/{keycode} {
      allow read, write: if isAdmin();
    }

    // ─── sign_in_events/{eventId} ────────────────────────────────────────────
    // Written only by Cloud Functions (admin SDK bypasses rules).
    // Admins can read for monitoring.
    match /sign_in_events/{eventId} {
      allow read: if isAdmin();
      allow write: if false; // Server-side only
    }

    // ─── password_reset_tokens/{tokenId} ─────────────────────────────────────
    // Created and consumed server-side only (admin SDK bypasses rules).
    match /password_reset_tokens/{tokenId} {
      allow read, write: if false; // Server-side only
    }

    // ─── guest_logs/{logId} ──────────────────────────────────────────────────
    // Guards create entries for their own site; guards can read their own.
    // Admin can read/write all.
    match /guest_logs/{logId} {
      allow create: if isAnyEmployee()
        && request.resource.data.guard_uid == request.auth.uid;
      allow read: if isAnyEmployee()
        && resource.data.guard_uid == request.auth.uid;
      allow update: if isAnyEmployee()
        && resource.data.guard_uid == request.auth.uid;
      allow read, write: if isAdmin();
    }

    // ─── patrol_checkpoints/{cpId} ───────────────────────────────────────────
    // Guards can read active checkpoints for their site (filtered server-side).
    // Only admins can create/update/delete.
    match /patrol_checkpoints/{cpId} {
      allow read: if isAnyEmployee() || isAdmin();
      allow write: if isAdmin();
    }

    // ─── patrol_logs/{logId} ─────────────────────────────────────────────────
    // Guards can create and read their own scan logs.
    // Admin can read/write all.
    match /patrol_logs/{logId} {
      allow create: if isAnyEmployee()
        && request.resource.data.guard_uid == request.auth.uid;
      allow read: if isAnyEmployee()
        && resource.data.guard_uid == request.auth.uid;
      allow read, write: if isAdmin();
    }

  }
}
