  "scripts": {
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --runInBand --watch"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "firebase-admin": "^12.0.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 20000,
    "globalSetup": "./setup.js",
    "globalTeardown": "./teardown.js"
  }
}
