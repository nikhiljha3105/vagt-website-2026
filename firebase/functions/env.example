# Copy this file to .env and fill in real values before deploying.
# .env is gitignored — never commit real secrets.

# Passphrase for the one-time first-admin setup endpoint.
# Set a long random string. Once the admin account is set up, this can be left unset.
SETUP_PASSPHRASE=

# Email of the first admin account (defaults to hello@vagtservices.com if unset).
FIRST_ADMIN_EMAIL=hello@vagtservices.com

# 2Factor.in API key — used to send OTP SMS to guards during registration + password reset.
# Get yours at https://2factor.in (free, instant signup)
# Production: set this in Firebase Console → Functions → [function] → Environment variables
TWOFACTOR_API_KEY=
