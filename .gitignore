# ── Credentials & Secrets ────────────────────────────────────────────────────
# NOTE: firebase-config.js is intentionally NOT ignored.
# Firebase client-side config (apiKey, authDomain, etc.) is safe to commit —
# it is not a secret. Security is enforced by Firestore Rules + Firebase Auth.
# The thing that must NEVER be committed is service account JSON (server-side).
.env
.env.*
*.env
service-account*.json
*-service-account.json
google-credentials*.json
secrets/
.secret*

# ── Firebase local ────────────────────────────────────────────────────────────
.firebase/
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log
database-debug.log
.runtimeconfig.json

# ── Node / Functions ──────────────────────────────────────────────────────────
node_modules/
firebase/functions/node_modules/
npm-debug.log*
yarn-error.log*
.pnp.*
.yarn/

# ── OS & Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/
.cache/

# ── Test artifacts ────────────────────────────────────────────────────────────
tests/__pycache__/
tests/*.pyc
